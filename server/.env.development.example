# Development overrides. Copy to `.env.local` for local work.

NODE_ENV=development
PORT=3000

# Use a dev Postgres on localhost
DB_HOST=localhost
DB_NAME=radha_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Mock SMS in dev so OTP appears in logs instead of being sent
SMS_PROVIDER=mock

# Quick-start JWT secrets for dev only — boot will fail in production
# because these match the placeholder pattern.
JWT_ACCESS_SECRET=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
JWT_REFRESH_SECRET=bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb

# Pretty logs are easier to read locally
LOG_FORMAT=pretty
LOG_LEVEL=debug

# Production checklist (the Zod ProductionEnvSchema enforces every
# rule in this file — boot will fail if any of these are wrong).

NODE_ENV=production
PORT=8080

# Real DB with TLS
DB_HOST=replace-with-rds-endpoint
DB_NAME=radha_prod
DB_USER=radha_app
DB_PASSWORD=replace-with-strong-password-min-16-chars
DB_SSL=true                          # MUST be true
DB_MAX_CONNECTIONS=40

# Redis with TLS
REDIS_HOST=replace-with-elasticache-endpoint
REDIS_TLS=true
REDIS_PASSWORD=replace-with-redis-auth

# Real AWS credentials (or use IAM instance roles in prod)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=replace
AWS_SECRET_ACCESS_KEY=replace
AWS_S3_BUCKET=radha-prod-media

# Real SMS — `mock` is rejected by the production schema
SMS_PROVIDER=msg91
MSG91_API_KEY=replace
MSG91_TEMPLATE_ID=replace

# Real JWT secrets — must be ≥64 chars and not be obvious placeholders
JWT_ACCESS_SECRET=replace-with-64-plus-cryptographically-random-chars-x
JWT_REFRESH_SECRET=replace-with-64-plus-cryptographically-random-chars-y

# Strict CORS — wildcard is forbidden
CORS_ORIGINS=https://radha.app,https://admin.radha.app

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

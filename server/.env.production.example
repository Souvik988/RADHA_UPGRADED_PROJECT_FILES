# ---------------------------------------------------------------------------
# RADHA server — PRODUCTION env template.  (Supersedes the older MSG91-based
# template — MSG91 was replaced by 2Factor.in.)
#
# Copy to `server/.env.production` and fill every <PLACEHOLDER>. The Zod
# validator (src/config/env.schema.ts) enforces STRICTER rules in production:
# real secrets, DB_SSL=true, no CORS "*", JWT ≥64 chars. The container reads
# this via `env_file` (docker-compose.prod.yml) — it is NEVER baked into the
# image. Keep it out of git (already gitignored).
#
# IMPORTANT: your existing `server/.env.development` already wires every key the
# app needs (incl. Gemini / allergen keys not shown in the original template).
# Start from THAT file and change the prod-specific values below.
# ---------------------------------------------------------------------------

# === Application ============================================================
NODE_ENV=production
PORT=3000
API_PREFIX=api
APP_NAME=RADHA
APP_VERSION=1.0.0

# === Database — AWS RDS (Postgres) ==========================================
# Endpoint from the RDS console (writer endpoint). DB_SSL MUST be true.
DB_HOST=<RDS_ENDPOINT>.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=radha
DB_USER=radha_app
DB_PASSWORD=<RDS_PASSWORD_MIN_16_CHARS>
DB_SSL=true
DB_SCHEMA=public
DB_MAX_CONNECTIONS=40
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=30000
# Used ONLY by the migrate/seed CLIs (`pnpm db:migrate`, `db:import:curated`).
# Same RDS instance; sslmode=require for the TLS handshake.
DATABASE_URL=postgresql://radha_app:<RDS_PASSWORD>@<RDS_ENDPOINT>.ap-south-1.rds.amazonaws.com:5432/radha?sslmode=require

# === Redis — AWS ElastiCache ================================================
# Primary endpoint. Set REDIS_TLS=true if the cluster has in-transit encryption
# (recommended); set REDIS_PASSWORD if you configured an AUTH token.
REDIS_HOST=<ELASTICACHE_PRIMARY_ENDPOINT>.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=<REDIS_AUTH_TOKEN_OR_BLANK>
REDIS_DB=0
REDIS_KEY_PREFIX=radha:
REDIS_TLS=true

# === AWS — S3 + CloudFront (media + product images) =========================
# Prefer an IAM instance role on the EC2 over static keys; if so, leave the
# ACCESS_KEY pair blank and the SDK uses the role.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=<IAM_ACCESS_KEY_ID_OR_BLANK_IF_INSTANCE_ROLE>
AWS_SECRET_ACCESS_KEY=<IAM_SECRET_ACCESS_KEY_OR_BLANK>
AWS_S3_BUCKET=radha-prod-media
AWS_S3_REGION=ap-south-1
AWS_S3_PRESIGNED_EXPIRY_SECONDS=600
AWS_CLOUDFRONT_DOMAIN=<DISTRIBUTION_ID>.cloudfront.net
AWS_CLOUDFRONT_KEY_PAIR_ID=
AWS_CLOUDFRONT_PRIVATE_KEY=

# === SMS / OTP — 2Factor.in =================================================
SMS_PROVIDER=2factor
TWO_FACTOR_API_KEY=<REAL_2FACTOR_API_KEY>
TWO_FACTOR_TEMPLATE=<DLT_TEMPLATE_NAME_OR_BLANK>
OTP_LENGTH=6
OTP_EXPIRY_SECONDS=600
OTP_MAX_ATTEMPTS_PER_HOUR=3

# === JWT — generate each with: openssl rand -hex 48 =========================
JWT_ACCESS_SECRET=<64+_CHAR_RANDOM_SECRET>
JWT_REFRESH_SECRET=<DIFFERENT_64+_CHAR_RANDOM_SECRET>
JWT_ACCESS_EXPIRY_SECONDS=1800
JWT_REFRESH_EXPIRY_SECONDS=2592000
JWT_ISSUER=radha-platform
JWT_AUDIENCE=radha-clients

# === CORS — no "*" in production ============================================
# The Flutter app isn't a browser origin, so it doesn't need CORS; list the
# owner-dashboard + marketing-web origins here once those ship.
CORS_ORIGINS=https://owner.YOURDOMAIN.com,https://www.YOURDOMAIN.com
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# === Rate limiting — behind nginx, so trust the proxy =======================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_TRUST_PROXY=true

# === Feature flags ==========================================================
FEATURE_AI_OCR=true
FEATURE_LLM_SUMMARIES=false
FEATURE_AWS_REKOGNITION=false
FEATURE_OFFLINE_SYNC=true
FEATURE_SUBSCRIPTIONS=true
FEATURE_OWNER_DASHBOARD=true
FEATURE_MARKETING_WEBSITE=true

# === Logging ================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_REDACT_KEYS=password,secret,token,key,authorization

# === Observability ==========================================================
SENTRY_DSN=<SENTRY_DSN_OR_BLANK>
SENTRY_TRACES_SAMPLE_RATE=0.1
AUDIT_LOG_ENABLED=true
CRITICAL_ALERT_EMAIL=<ops@YOURDOMAIN.com>

# === Razorpay / Payments — LIVE keys from the Razorpay dashboard ============
RAZORPAY_KEY_ID=<RAZORPAY_LIVE_KEY_ID>
RAZORPAY_KEY_SECRET=<RAZORPAY_LIVE_KEY_SECRET>
RAZORPAY_WEBHOOK_SECRET=<RAZORPAY_WEBHOOK_SECRET>

# === Plus any extra keys from your .env.development =========================
# e.g. GEMINI_API_KEY / allergen provider key — copy them across so the AI
# label-analysis + allergen features work in prod.

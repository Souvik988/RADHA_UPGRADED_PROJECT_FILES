# ---------------------------------------------------------------------------
# Razorpay (BE-28 v2) — env template
#
# The backend integrates Razorpay through src/integrations/razorpay/.
# When RAZORPAY_KEY_ID is empty, RazorpayService falls back to a
# deterministic mock provider so local payment flows work offline.
# Production validation requires non-empty values for all three keys.
#
# Provision a sandbox account: https://dashboard.razorpay.com/app/keys
# Configure the webhook URL: https://<your-host>/api/v1/payments/webhooks/razorpay
# ---------------------------------------------------------------------------

# Test mode key id (starts with rzp_test_). In production swap for rzp_live_.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx

# Test mode key secret. NEVER commit a live key.
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Razorpay-dashboard configured webhook secret (Settings → Webhooks).
# Used to verify the X-Razorpay-Signature header on inbound webhooks
# via timing-safe HMAC-SHA256 comparison.
RAZORPAY_WEBHOOK_SECRET=

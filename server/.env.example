# ---------------------------------------------------------------------------
# RADHA server — env template (BE-02)
#
# Copy this file to `server/.env.local` for local development, or to
# `server/.env.production` for prod. The Zod validator in
# `src/config/env.schema.ts` enforces stricter rules when NODE_ENV is
# `production` or `staging` (TLS, real secrets, no CORS wildcards).
# ---------------------------------------------------------------------------

# === Application =============================================================
NODE_ENV=development        # development | test | staging | production
PORT=3000
API_PREFIX=api
APP_NAME=RADHA
APP_VERSION=1.0.0

# === Database (BE-05) ========================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=radha_dev
DB_USER=postgres
DB_PASSWORD=                # required, ≥16 chars in production
DB_SSL=false                # MUST be true in production
DB_SCHEMA=public
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=30000

# === Redis (BE-24, BE-32, BE-46) =============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=radha:
REDIS_TLS=false

# === AWS (BE-13, BE-21, BE-23) ===============================================
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=          # required in production
AWS_SECRET_ACCESS_KEY=      # required in production
AWS_S3_BUCKET=radha-dev-media
AWS_S3_REGION=ap-south-1
AWS_S3_PRESIGNED_EXPIRY_SECONDS=600
AWS_CLOUDFRONT_DOMAIN=
AWS_CLOUDFRONT_KEY_PAIR_ID=
AWS_CLOUDFRONT_PRIVATE_KEY=

# === SMS (BE-06) =============================================================
SMS_PROVIDER=mock           # mock for dev, msg91 in production
MSG91_API_KEY=
MSG91_SENDER_ID=RADHA1
MSG91_TEMPLATE_ID=
OTP_LENGTH=6
OTP_EXPIRY_SECONDS=600
OTP_MAX_ATTEMPTS_PER_HOUR=3

# === JWT (BE-06+) ============================================================
JWT_ACCESS_SECRET=          # ≥32 chars dev, ≥64 chars production
JWT_REFRESH_SECRET=         # ≥32 chars dev, ≥64 chars production
JWT_ACCESS_EXPIRY_SECONDS=1800
JWT_REFRESH_EXPIRY_SECONDS=2592000
JWT_ISSUER=radha-platform
JWT_AUDIENCE=radha-clients

# === CORS ====================================================================
CORS_ORIGINS=http://localhost:3000   # comma-separated; "*" forbidden in prod
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# === Rate limiting (BE-08, BE-46) ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_TRUST_PROXY=false

# === Feature flags ===========================================================
FEATURE_AI_OCR=true
FEATURE_LLM_SUMMARIES=false
FEATURE_AWS_REKOGNITION=false
FEATURE_OFFLINE_SYNC=true
FEATURE_SUBSCRIPTIONS=true
FEATURE_OWNER_DASHBOARD=true
FEATURE_MARKETING_WEBSITE=true

# === Logging (BE-04) =========================================================
LOG_LEVEL=info              # error | warn | info | debug | verbose
LOG_FORMAT=json             # json | pretty
LOG_REDACT_KEYS=password,secret,token,key,authorization

# === Observability (BE-04) ===================================================
SENTRY_DSN=                 # leave blank in dev to disable Sentry
SENTRY_TRACES_SAMPLE_RATE=0.1
AUDIT_LOG_ENABLED=true
CRITICAL_ALERT_EMAIL=

# === Razorpay / Payments (BE-28 v2) ==========================================
# Test keys are safe to commit; live keys MUST come from secret manager.
# Empty values activate the deterministic mock provider in dev.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

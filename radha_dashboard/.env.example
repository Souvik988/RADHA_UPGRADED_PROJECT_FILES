# RADHA Admin Dashboard — environment variables template
# Copy to .env.local and fill in real values. .env.local is git-ignored.
# Only NEXT_PUBLIC_* vars are embedded in the client bundle (Doc 3 §B.4).

# API base URL (public — no secret)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1

# Session cookie name (used by Route Handlers / server actions)
SESSION_COOKIE_NAME=radha_session

# Sentry DSN (optional — public, only the project DSN, not the auth token)
NEXT_PUBLIC_SENTRY_DSN=

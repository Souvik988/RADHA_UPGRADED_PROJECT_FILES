# Keep the build context small + the image clean. The server image never needs
# the Flutter app, design assets, git history, or any node_modules (pnpm
# reinstalls inside the image from the lockfile).
**/node_modules
**/dist
**/.git
.git
**/*.log

# The Flutter app + its (large) bundled assets are irrelevant to the server.
apps/mobile
apps/marketing-web
apps/owner-dashboard

# Local env / secrets must never enter the image (env is injected at runtime).
**/.env
**/.env.*
!**/.env.example
!**/.env.production.example

# Dev-only + heavy/irrelevant dirs.
.kiro
**/.tmp
**/coverage
**/*.tsbuildinfo
**/assets/_fullres_backup
**/build
**/.dart_tool
Dockerfile
docker-compose*.yml
deploy
**/*.md

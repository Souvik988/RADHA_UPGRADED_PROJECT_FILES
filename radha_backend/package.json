{
  "name": "@radha/radha_backend",
  "version": "1.0.0",
  "private": true,
  "description": "radha_backend — NestJS API + Worker + Scheduler",
  "license": "UNLICENSED",
  "pnpm": {
    "overrides": {
      "ioredis": "5.10.1"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "bcrypt",
      "es5-ext",
      "esbuild",
      "msgpackr-extract",
      "protobufjs",
      "sharp"
    ]
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build && tsc-alias -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.api",
    "start:worker": "node dist/main.worker",
    "start:scheduler": "node dist/main.scheduler",
    "lint": "eslint \"{src,test}/**/*.ts\" --max-warnings 0",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:generate": "drizzle-kit generate:pg",
    "db:push": "drizzle-kit push:pg",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:import:catalog": "ts-node -r tsconfig-paths/register src/db/import-catalog.ts",
    "db:import:curated": "ts-node -r tsconfig-paths/register src/db/import-curated-catalog.ts",
    "db:host:images": "ts-node -r tsconfig-paths/register src/db/host-catalog-images.ts",
    "db:reset": "tsx src/db/reset.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.529.0",
    "@aws-sdk/client-rekognition": "3.622.0",
    "@aws-sdk/client-s3": "^3.529.0",
    "@aws-sdk/s3-presigned-post": "^3.529.0",
    "@aws-sdk/s3-request-presigner": "^3.529.0",
    "@google-cloud/vision": "4.3.2",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/terminus": "^10.2.0",
    "@sentry/node": "^7.99.0",
    "@types/bcryptjs": "^3.0.0",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.7.4",
    "csv-parse": "^5.5.5",
    "drizzle-orm": "^0.29.3",
    "exceljs": "^4.4.0",
    "firebase-admin": "^12.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "nestjs-cls": "^4.3.0",
    "nestjs-pino": "^4.0.0",
    "openai": "4.104.0",
    "pdfkit": "^0.14.0",
    "pino": "^8.17.0",
    "pino-http": "^9.0.0",
    "pino-pretty": "^10.3.0",
    "postgres": "^3.4.3",
    "razorpay": "^2.9.4",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.2",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.1",
    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/pdfkit": "^0.13.4",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "drizzle-kit": "^0.20.13",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@radha/shared-types$": "<rootDir>/shared-types"
    }
  }
}
